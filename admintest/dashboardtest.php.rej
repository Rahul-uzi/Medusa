-.sidebar::-webkit-scrollbar-thumb {
-    background: rgba(223, 186, 134, 0.4);
-    border-radius: 4px;
-}
-.sidebar::-webkit-scrollbar-thumb:hover {
-    background: rgba(223, 186, 134, 0.8);
