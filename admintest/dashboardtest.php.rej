-/* ===== CHATGPT FINAL UI FIX ===== */
-.sidebar{
-    transition:all .3s ease;
-    width:260px;
-    height: 100vh;
-    overflow-y: auto;
-}
-.sidebar::-webkit-scrollbar {
-    width: 6px;
-}
-.sidebar::-webkit-scrollbar-track {
-    background: transparent;
